{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "DiscoConfiguration",
    "description": "Schema for Disco Application Configuration",
    "type": "object",
    "properties": {
        "discoConfiguration":{
            "description": "Disco Application Configuration Root",
            "type": "object",
            "properties": {
                "serverConfiguration": {
                    "description": "Disco Server Application Configuration Root",
                    "type": "object",
                    "required": ["security"],
                    "properties": {
                        "localization": {
                            "description": "Disco Server Localization Configuration",
                            "type": "object",
                            "required": ["culture"],
                            "properties": {
                                "culture": {
                                    "$ref": "Definitions::CultureInfo",
                                    "description": "Disco Server Current-Culture Name",
                                    "default": "zh-CN"
                                }
                            }
                        },
                        "authentication": {
                            "description": "Disco Server Authentication Configuration",
                            "type": "object",
                            "properties": {
                                "authenticateRequired": {
                                    "description": "Authentication is required",
                                    "type": "boolean",
                                    "default": true
                                },
                                "defaultAdministratorCredentials": {
                                    "default": "The default administrator credentials",
                                    "type": "object",
                                    "required": ["userName"],
                                    "properties": {
                                        "userName": {
                                            "description": "The user-name",
                                            "type": "string",
                                            "minLength": 2,
                                            "default": "sa"
                                        },
                                        "initialPassword": {
                                            "description": "The initial password",
                                            "type": "string",
                                            "minLength": 6,
                                            "default": "disco@2023"
                                        },
                                        "changePasswordRequired": {
                                            "description": "The initial password must be modified",
                                            "type": "boolean",
                                            "default": "true"
                                        }
                                    }
                                }
                            }
                        },
                        "security": {
                            "description": "Disco Server Security Configuration",
                            "type": "object",
                            "required": ["defaultSecretKey"],
                            "properties": {
                                "defaultSecretKey": {
                                    "description": "The secret-key for encryption configuration",
                                    "type": "string",
                                    "minLength": 16,
                                    "maxLength": 16
                                }
                            }
                        },
                        "connectionStrings": {
                            "description": "Disco Server Database ConnectionStrings Configuration",
                            "type": "array",
                            "items": {
                                "type": "object",
                                "required": ["name", "connectionString"],
                                "properties": {
                                    "name": {
                                        "description": "The name of connection",
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "connectionString": {
                                        "minLength": 1,
                                        "description": "The connectoin string",
                                        "type": "string"
                                    },
                                    "readonlyConnectionStrings": {
                                        "description": "The connection strings for read-only slaves",
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "minLength": 1
                                        }
                                    }
                                }
                            }
                        },
                        "notification": {
                            "description": "Disco Server Notification Configuration",
                            "type": "object",
                            "required": ["emailNotification"],
                            "properties": {
                                "emailNotification": {
                                    "description": "Email notification configuration",
                                    "type": "object",
                                    "required": ["smtpServerUri", "smtpServerPort", "sender"],
                                    "properties": {
                                        "smtpServerUri": {
                                            "description": "SMTP mail server host name",
                                            "type": "string",
                                            "minLength": 1
                                        },
                                        "smtpServerPort": {
                                            "description": "SMTP mail server port number",
                                            "type": "number",
                                            "minimum": 1,
                                            "maximum": 65535
                                        },
                                        "subjectTemplate": {
                                            "description": "Notification email theme template",
                                            "type": "string",
                                            "default": "Disco 通知：{0}"
                                        },
                                        "sender": {
                                            "description": "Notification sender configuration",
                                            "type": "object",
                                            "required": ["address", "userName", "password"],
                                            "properties": {
                                                "address": {
                                                    "description": "Sender's e-mail address",
                                                    "type": "string",
                                                    "minLength": 1
                                                },
                                                "friendlyName": {
                                                    "description": "Notify sender email address friendly name",
                                                    "default": "Disco - Distributed Configuraton Service",
                                                    "type": "string"
                                                },
                                                "userName": {
                                                    "description": "Login email username",
                                                    "type": "string",
                                                    "minLength": 1
                                                },
                                                "password": {
                                                    "description": "The password",
                                                    "type": "string",
                                                    "minLength": 8
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "CultureInfo":{
            "type": "string",
            "enum": ["zh-CN", "en-US", "zh-TW"],
            "$id": "Definitions::CultureInfo"
        }
    }
}